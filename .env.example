# Yield Intelligence — env vars reference

# Environment: local | staging | production
ENVIRONMENT=local

# Database — SQLite for local dev; Postgres for production
# DATABASE_URL=postgresql://user:pass@host:port/dbname
DATABASE_URL=sqlite:///./yield_intelligence.db

# CORS origins — comma-separated in production (on Railway, set to your own domain)
# CORS_ORIGINS=https://yieldintel.example.com,https://admin.yieldintel.example.com

# Seeding — run once on first boot to populate DB with Acme data
SEED_ON_STARTUP=true

# Default workspace — hardcoded for single-tenant v1
DEFAULT_WORKSPACE=acme_retail
DEFAULT_DATASET=5yr

# MMM settings
MMM_USE_PRETRAINED=true
MMM_DRAWS=1000
MMM_TUNE=1000
MMM_CHAINS=2
