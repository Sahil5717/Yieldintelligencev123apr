{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.11",
    "node": "20"
  },
  "steps": {
    "install": {
      "commands": [
        "pip install -r requirements.txt",
        "cd frontend && npm ci"
      ]
    },
    "build": {
      "inputs": [{"step": "install"}],
      "commands": [
        "cd frontend && npm run build",
        "mkdir -p backend/static && cp -r frontend/dist/* backend/static/"
      ]
    }
  },
  "deploy": {
    "startCommand": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}
